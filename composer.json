{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "ercogx/laravel-filament-starter-kit",
    "type": "project",
    "description": "This is a Filament v5 Starter Kit for Laravel 13, designed to accelerate the development of Filament-powered applications.",
    "keywords": [
        "laravel",
        "framework",
        "glow starter kit",
        "livewire",
        "filament"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "al-saloul/filament-image-gallery": "^3.0",
        "awcodes/filament-quick-create": "^5.0",
        "bezhansalleh/filament-exceptions": "^4.2",
        "bezhansalleh/filament-shield": "^4.2",
        "businesstilto/commentable": "^0.3.7",
        "danihidayatx/image-optimizer": "^2.1",
        "devonab/filament-easy-footer": "^2.2",
        "emuniq/filament-browser-notifications": "^1.1",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.5",
        "guava/calendar": "^3.1",
        "inerba/filament-db-config": "^1.3",
        "jacobtims/filament-logger": "^1.2",
        "jeffgreco13/filament-breezy": "^3.2",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0.0",
        "leandrocfe/filament-apex-charts": "^5.1",
        "leek/filament-dicebear": "^1.2",
        "moataz-01/filament-notification-sound": "^1.0",
        "pxlrbt/filament-excel": "^3.6",
        "spykapps/theme-edinburgh": "^1.0",
        "stechstudio/filament-impersonate": "^5.3",
        "swisnl/filament-backgrounds": "^2.0",
        "webklex/laravel-imap": "^6.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.5",
        "pestphp/pest-plugin-laravel": "^4.1",
        "plannr/laravel-fast-refresh-database": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "check": [
            "./vendor/bin/pint --dirty",
            "php artisan test",
            "./vendor/bin/phpstan analyse --memory-limit=2G"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
